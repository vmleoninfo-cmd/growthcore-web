4].actions; 'value'; 'action_type'; 'lead')); '0')}}\"},{\"date\":\"{{4.data.data[5].date_start}}\",\"spend\":\"{{4.data.data[5].spend}}\",\"impressions\":\"{{4.data.data[5].impressions}}\",\"clicks\":\"{{4.data.data[5].clicks}}\",\"leads\":\"{{ifempty(first(map(4.data.data[5].actions; 'value'; 'action_type'; 'lead')); '0')}}\"},{\"date\":\"{{4.data.data[6].date_start}}\",\"spend\":\"{{4.data.data[6].spend}}\",\"impressions\":\"{{4.data.data[6].impressions}}\",\"clicks\":\"{{4.data.data[6].clicks}}\",\"leads\":\"{{ifempty(first(map(4.data.data[6].actions; 'value'; 'action_type'; 'lead')); '0')}}\"},{\"date\":\"{{4.data.data[7].date_start}}\",\"spend\":\"{{4.data.data[7].spend}}\",\"impressions\":\"{{4.data.data[7].impressions}}\",\"clicks\":\"{{4.data.data[7].clicks}}\",\"leads\":\"{{ifempty(first(map(4.data.data[7].actions; 'value'; 'action_type'; 'lead')); '0')}}\"}],\"campaigns\":[{\"name\":\"{{5.data.data[1].campaign_name}}\",\"spend\":\"{{5.data.data[1].spend}}\",\"leads\":\"{{ifempty(first(map(5.data.data[1].actions; 'value'; 'action_type'; 'lead')); '0')}}\",\"cpl\":0,\"clicks\":\"{{5.data.data[1].clicks}}\",\"impressions\":\"{{5.data.data[1].impressions}}\"},{\"name\":\"{{5.data.data[2].campaign_name}}\",\"spend\":\"{{5.data.data[2].spend}}\",\"leads\":\"{{ifempty(first(map(5.data.data[2].actions; 'value'; 'action_type'; 'lead')); '0')}}\",\"cpl\":0,\"clicks\":\"{{5.data.data[2].clicks}}\",\"impressions\":\"{{5.data.data[2].impressions}}\"},{\"name\":\"{{5.data.data[3].campaign_name}}\",\"spend\":\"{{5.data.data[3].spend}}\",\"leads\":\"{{ifempty(first(map(5.data.data[3].actions; 'value'; 'action_type'; 'lead')); '0')}}\",\"cpl\":0,\"clicks\":\"{{5.data.data[3].clicks}}\",\"impressions\":\"{{5.data.data[3].impressions}}\"}],\"platforms\":[{\"name\":\"{{capitalize(6.data.data[1].publisher_platform)}}\",\"spend\":\"{{6.data.data[1].spend}}\",\"leads\":\"{{ifempty(first(map(6.data.data[1].actions; 'value'; 'action_type'; 'lead')); '0')}}\",\"impressions\":\"{{6.data.data[1].impressions}}\"},{\"name\":\"{{capitalize(6.data.data[2].publisher_platform)}}\",\"spend\":\"{{6.data.data[2].spend}}\",\"leads\":\"{{ifempty(first(map(6.data.data[2].actions; 'value'; 'action_type'; 'lead')); '0')}}\",\"impressions\":\"{{6.data.data[2].impressions}}\"}]}" }
        ],
        "requestCompressedContent": true
