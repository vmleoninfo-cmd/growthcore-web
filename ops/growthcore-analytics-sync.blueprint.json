        "url": "https://graph.facebook.com/v25.0/act_YOUR_GROWTHCORE_AD_ACCOUNT/insights?fields=ad_name,impressions,clicks,spend&date_preset=last_7d&level=ad&access_token=YOUR_META_ACCESS_TOKEN",
        "method": "get",
